DOPRAX_API_KEY=your-api-key-here
DOPRAX_BASE_URL=https://www.doprax.com
PHOENIX_OUTPUT_DIR=phoenix-output
DEFAULT_PROXY=socks5://127.0.0.1:1080
PHOENIX_EXCLUDED_LOCATIONS=germany,de,france,fr,paris
PHOENIX_SSH_USER=marj
# Optional override if Doprax password API unavailable:
# PHOENIX_SSH_PASSWORD=your-server-password

# Panel (web/)
PHOENIX_PANEL_PORT=5050
SECRET_KEY=your_secret_key_here
PHOENIX_PANEL_USER=admin
