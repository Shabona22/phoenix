# .cursorrules – تنظیمات خودکار Cursor برای پروژه Phoenix (DBF Ready)
rules:
  - pattern: "src/simulator/*.py"
    model: "claude-3.5-sonnet"
    description: "شبیه‌ساز DBF – نیاز به معماری دقیق"
  - pattern: "src/protocols/no_tls/*.py"
    model: "gpt-4-turbo"
    description: "پروتکل‌های بدون TLS – اولویت بحرانی"
  - pattern: "src/protocols/*.py"
    model: "gpt-4-turbo"
    description: "تولید و ویرایش کانفیگ پروتکل‌ها"
  - pattern: "src/research/*.py"
    model: "gpt-4-turbo"
    description: "Research Agent – تحلیل DBF"
  - pattern: "src/ai/*.py"
    model: "gpt-4-turbo"
    description: "ماژول‌های هوش مصنوعی"
  - pattern: "src/security/*.py"
    model: "gpt-4-turbo"
    description: "امنیت و Kill Switch"
  - pattern: "src/healer/*.py"
    model: "gpt-3.5-turbo"
    description: "خودترمیمی و Fallback"
  - pattern: "src/utils/*.py"
    model: "gpt-3.5-turbo"
    description: "ابزارهای کمکی و Config Tester"
  - pattern: "web/*.py"
    model: "gpt-3.5-turbo"
    description: "پنل Flask"
  - pattern: "*.sh"
    model: "base"
    description: "اسکریپت‌های شل"
  - pattern: "requirements.txt"
    model: "base"
    description: "فایل وابستگی"
general:
  max_tokens: 4096
  temperature: 0.3
  auto_run_tests: true
  fallback_model: "gpt-3.5-turbo"
  priority: "critical_first"
